# LUMEN ALPHA Trading Bot Configuration
# Copy to .env and fill in your values

# Server
PORT=8080
WEBHOOK_SECRET=your-secret-key-here

# Trading Mode
TRADING_MODE=paper  # 'paper' or 'live'

# Capital
INITIAL_CAPITAL=1000

# ML Service (Elim's DGX Spark)
ML_ENDPOINT=http://100.79.93.27:5000

# Hyperliquid
HYPERLIQUID_API_KEY=your-key
HYPERLIQUID_API_SECRET=your-secret
HYPERLIQUID_TESTNET=false

# Bybit
BYBIT_API_KEY=your-key
BYBIT_API_SECRET=your-secret
BYBIT_TESTNET=false

# Notifications
WHATSAPP_ENABLED=true
WHATSAPP_TARGET=+19495422279

# Logging
LOG_LEVEL=info  # debug, info, warn, error
